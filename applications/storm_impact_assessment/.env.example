# =============================================================================
# # 🌀 Hurricane Path Prediction & ⚡Infrastructure Impact Analysis  - Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# The .env file is gitignored and will not be committed
#
# You can also set these as system environment variables instead of using .env
# If a value is not found, the notebook will prompt you to enter it interactively
# =============================================================================

# GeoCatalog Configuration
# Your GeoCatalog base URI (without /stac or other API suffixes)
GEOCATALOG_URI=https://your-geocatalog.your-region.geocatalog.spatio.azure.com

# Aurora Foundry Configuration
# Microsoft Aurora model endpoint(copy endpoint from Azure AI Studio) and authentication(copy api endpoint key from Azure AI Studio)
AURORA_FOUNDRY_ENDPOINT=https://your-aurora-endpoint.your-region.inference.ml.azure.com/score
AURORA_FOUNDRY_TOKEN=your-foundry-token-here

# Azure Blob Storage Configuration
# Container-level SAS URL for Aurora SDK's BlobStorageChannel (Read, Write, List)
# Format: https://<account>.blob.core.windows.net/<container>?sp=...&sig=...
AURORA_BLOB_STORAGE_SAS=https://youraccount.blob.core.windows.net/container?your_sas_token_here

# Container name and account key for uploading data and generating SAS URLs
# used during GeoCatalog STAC ingestion (Azure Portal → Storage account → Access keys)
UPLOAD_CONTAINER_NAME=your-container-name
STORAGE_ACCOUNT_KEY=your_storage_account_key_here

#=============================================================================

