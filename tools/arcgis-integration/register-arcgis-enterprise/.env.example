# =============================================================================
# MPC Pro GeoCatalog Configuration
# =============================================================================

# GeoCatalog endpoint URL
GEOCATALOG_ENDPOINT=https://my-geocatalog.geocatalog.spatio.azure.com

# =============================================================================
# ArcGIS Enterprise Configuration
# =============================================================================

# ArcGIS Enterprise Portal URL
ARCGIS_PORTAL_URL=https://portal.domain.com/portal

# Portal admin credentials
ARCGIS_USERNAME=admin
ARCGIS_PASSWORD=

# Set to true to skip SSL certificate verification (not recommended for production)
ARCGIS_VERIFY_CERT=true

# Server role to register cloud stores with: HOSTING_SERVER or IMAGE_SERVER
ARCGIS_SERVER_ROLE=IMAGE_SERVER

# =============================================================================
# Storage Credential Type
# =============================================================================
# Choose one: service_principal, access_key, managed_identity, sas_token
STORAGE_CREDENTIAL_TYPE=service_principal

# --- Service Principal (Entra ID) ---
# Set to true (default) to create a new service principal automatically,
# or false to use an existing one (provide AZURE_CLIENT_ID and AZURE_CLIENT_SECRET below).
CREATE_SERVICE_PRINCIPAL=true
SP_DISPLAY_NAME=ArcGIS-Server-GeocatalogReader

# Azure subscription for role assignments (auto-detected if empty)
AZURE_SUBSCRIPTION_ID=

# Existing service principal credentials (only needed if CREATE_SERVICE_PRINCIPAL=false)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Access Key ---
# STORAGE_ACCOUNT_KEY=

# --- Managed Identity ---
# MANAGED_IDENTITY_CLIENT_ID=

# --- SAS Token ---
# SAS_TOKEN=
