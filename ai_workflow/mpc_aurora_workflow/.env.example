# =============================================================================
# # 🌀 Hurricane Path Prediction & ⚡Infrastructure Impact Analysis  - Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# The .env file is gitignored and will not be committed
#
# You can also set these as system environment variables instead of using .env
# If a value is not found, the notebook will prompt you to enter it interactively
# =============================================================================

# STAC Catalog Configuration
# GeoCatalog STAC API endpoint for ingesting and querying data
STAC_CATALOG_URL=https://your-geocatalog.spatio.azure.com/api/stac/v1

# Aurora Foundry Configuration
# Microsoft Aurora model endpoint and authentication
AURORA_FOUNDRY_ENDPOINT=https://your-aurora-endpoint.inference.ai.azure.com
AURORA_FOUNDRY_TOKEN=your-foundry-token-here

# Azure Blob Storage Configuration
# SAS URL for Aurora BlobStorageChannel (account-level SAS for Aurora inference)
# Format: https://youraccount.blob.core.windows.net/?sv=2023-01-01&...
AURORA_BLOB_STORAGE_SAS=https://youraccount.blob.core.windows.net/container?your_sas_token_here

# Container name for uploading model data and results
UPLOAD_CONTAINER_NAME=your-container-name

# Storage account key (for generating SAS tokens for uploaded files)
STORAGE_ACCOUNT_KEY=your_storage_account_key_here

# Output Blob Container URL for storing inference results
OUTPUT_BLOB_CONTAINER_URL=https://youraccount.blob.core.windows.net/your-container-name

#=============================================================================

